---
// BaseLayout.astro — outer shell for every page.
// Owns: <html>, <head> (via BaseHead + inline theme script), <body>, Header, Footer.
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

interface Props {
  title: string;
  description?: string;
  image?: string; // absolute URL for og:image
  ogType?: 'website' | 'article'; // pass 'article' from BlogPost; defaults to 'website'
  publishedTime?: string;          // ISO 8601 (articles)
  modifiedTime?: string;           // ISO 8601 (articles)
  author?: string;                 // article:author (articles)
}

const { title = SITE_TITLE, description, image, ogType, publishedTime, modifiedTime, author } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      ogType={ogType}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
    />

    <!--
      No-FOUC theme init — MUST be inline, MUST be before any stylesheet that paints.
      Runs synchronously before the browser paints the first frame.
      Order of preference:
        1. User's saved choice in localStorage
        2. OS prefers-color-scheme (light wins; dark wins when unset → default dark)
    -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var theme = stored
          ? stored
          : window.matchMedia('(prefers-color-scheme: light)').matches
            ? 'light'
            : 'dark'; // default dark when no preference
        if (theme === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }
        // Keep browser-chrome color in sync with the resolved theme.
        // The meta is emitted by BaseHead.astro (above this script in the DOM)
        // so it is already present when this runs synchronously.
        var themeMeta = document.getElementById('theme-color-meta');
        if (themeMeta) {
          themeMeta.setAttribute('content', theme === 'light' ? '#F7F4EF' : '#0F1115');
        }
      })();
    </script>

    <!-- Named slot for per-page head content (e.g. BlogPosting JSON-LD from BlogPost.astro). -->
    <slot name="head" />
  </head>
  <body>
    <!-- Skip-to-content: first tab stop, visible on focus, jumps past the header -->
    <a href="#main" class="skip-link">Skip to content</a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />
  </body>
</html>
