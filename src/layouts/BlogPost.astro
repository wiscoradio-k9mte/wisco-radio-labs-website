---
// BlogPost.astro — article frame.
// Wraps BaseLayout, adds: hero image, eyebrow, H1, meta row, optional YouTube embed, prose slot.
// Also injects BlogPosting JSON-LD into <head> via the named "head" slot in BaseLayout.
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { withBase } from '../lib/link';
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  heroCaption?: string;
  tags?: string[];
  youtube?: string;
}

const { title, description, pubDate, updatedDate, heroImage, heroCaption, tags = [], youtube } = Astro.props;

// JSON-LD: BlogPosting — per-article, injected into <head> via BaseLayout's head slot.
// Astro.url.href is the canonical URL for this post (site + base + slug, already correct).
const postSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  url: Astro.url.href,
  ...(tags.length > 0 ? { keywords: tags.join(', ') } : {}),
  author: {
    '@type': 'Person',
    name: 'Travis Engh',
    callSign: 'K9MTE',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Wisco Radio Labs',
  },
});

// Rough reading time: ~200 wpm. We don't have word count at layout render time,
// but the slot content will fill it. Omit estimate for now (accurate word count
// would need a remark plugin — noted as a future nice-to-have).
---
<BaseLayout
  title={title}
  description={description}
  ogType="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate ? updatedDate.toISOString() : undefined}
  author="Travis Engh"
>
  <!-- BlogPosting JSON-LD injected into <head> via BaseLayout's named slot.
       is:inline silences the Astro hint — intentionally a raw JSON block. -->
  <script is:inline type="application/ld+json" slot="head" set:html={postSchema} />

  <article class="blog-article">
    <!-- Hero image (full width, above the title) -->
    {heroImage && (
      <figure class="article-hero-wrap container">
        <Image
          src={heroImage}
          alt=""
          width={1200}
          height={675}
          class="article-hero-img"
          loading="eager"
          decoding="async"
        />
        {heroCaption && <figcaption class="article-hero-caption">{heroCaption}</figcaption>}
      </figure>
    )}

    <!-- Article header -->
    <div class="article-header container">
      {tags.length > 0 && (
        <p class="eyebrow">{tags[0]}</p>
      )}
      <h1 class="article-title">{title}</h1>
      <p class="article-meta">
        <FormattedDate date={pubDate} />
        {updatedDate && updatedDate > pubDate && (
          <> &middot; Updated <FormattedDate date={updatedDate} /></>
        )}
        &middot; K9MTE
      </p>
    </div>

    <!-- Optional YouTube embed (above the prose) -->
    {youtube && (
      <div class="article-youtube container">
        <YouTubeEmbed id={youtube} title={title} />
      </div>
    )}

    <!-- Article body — Markdown rendered inside .prose -->
    <div class="article-body container">
      <!-- Live region: announces copy-to-clipboard success to screen readers.
           Injected once per page here rather than created dynamically so the
           element is guaranteed present before the script runs. -->
      <p id="prose-copy-status" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></p>
      <div class="prose">
        <slot />
      </div>

      <!-- Tags at the bottom — plain labels, not links (tag filter not yet built). -->
      {tags.length > 0 && (
        <div class="article-tags">
          <hr />
          <div class="article-tags-list">
            <span class="article-tags-label">Tagged:</span>
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      )}

      <!-- Back link — readers who land deep-linked have no path onward without this. -->
      <p class="back-link-wrap">
        <a href={withBase('/blog/')}>&#8592; All posts</a>
      </p>
    </div>
  </article>
</BaseLayout>

<script>
  // ── Blog code-block copy buttons ───────────────────────────────────────────
  // Dynamically adds a "Copy" button to every <pre> inside .prose on a blog post.
  // Reuses the same aria-live pattern as the Products install-card copy button.
  // Does NOT touch the Products page — this script only fires on blog post pages
  // (BlogPost.astro is only used there) and only looks at .prose pre elements.

  const copyStatus = document.getElementById('prose-copy-status');

  document.querySelectorAll<HTMLPreElement>('.prose pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'prose-copy-btn';
    btn.type = 'button';
    btn.setAttribute('aria-label', 'Copy code block');
    btn.innerHTML = '<span class="copy-label">Copy</span>';

    btn.addEventListener('click', async () => {
      // Prefer the <code> text; fall back to the whole <pre> if no <code> child.
      const code = pre.querySelector('code');
      const text = (code ?? pre).textContent ?? '';
      const label = btn.querySelector<HTMLElement>('.copy-label');
      try {
        await navigator.clipboard.writeText(text);
        if (label) {
          label.textContent = 'Copied!';
          setTimeout(() => { label.textContent = 'Copy'; }, 2000);
        }
        if (copyStatus) {
          copyStatus.textContent = 'Code copied to clipboard.';
          setTimeout(() => { copyStatus.textContent = ''; }, 2000);
        }
      } catch {
        // Clipboard API unavailable — announce so AT users know to copy manually.
        if (copyStatus) {
          copyStatus.textContent = "Couldn't copy — select the code and copy it manually.";
          setTimeout(() => { copyStatus.textContent = ''; }, 4000);
        }
      }
    });

    // Append inside <pre> and position absolutely — standard code-copy pattern.
    pre.style.position = 'relative';
    pre.appendChild(btn);
  });
</script>

<style>
  .blog-article {
    padding-bottom: var(--space-12);
  }

  /* Hero — aligned to the article column and shown at its natural 16:9 ratio.
     (Was full-bleed with max-height + object-fit:cover, which cropped the image
     into a short band on desktop.) */
  .article-hero-wrap {
    max-width: var(--measure);
    margin: 0 auto var(--space-8);
  }

  .article-hero-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-md);
  }

  .article-hero-caption {
    margin-top: var(--space-2);
    text-align: center;
    font-size: var(--fs-caption);
    color: var(--text-muted);
  }

  /* Header */
  .article-header {
    max-width: var(--measure);
    margin-block: var(--space-8);
  }

  .article-title {
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.015em;
    font-family: var(--font-display);
    color: var(--text);
    margin: 0 0 var(--space-4);
  }

  .article-meta {
    font-size: var(--fs-small);
    color: var(--text-muted);
    margin: 0;
  }

  /* YouTube */
  .article-youtube {
    max-width: var(--measure);
    margin-bottom: var(--space-6);
  }

  /* Body */
  .article-body {
    max-width: var(--measure);
  }

  /* Tags footer */
  .article-tags hr {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: var(--space-5);
  }

  .article-tags-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .article-tags-label {
    font-size: var(--fs-caption);
    font-weight: 500;
    color: var(--text-secondary);
    margin-right: var(--space-1);
  }

  .back-link-wrap {
    margin-top: var(--space-8);
    font-size: var(--fs-small);
  }

  /* ── Code-block copy button ───────────────────────────────────────────────── */
  /* Absolutely positioned inside <pre> (pre.style.position is set by script).
     Matches the Products install card .copy-btn visually. */
  :global(.prose-copy-btn) {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    display: flex;
    align-items: center;
    min-height: 32px;
    padding: var(--space-1) var(--space-3);
    background: var(--surface-1);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-family: var(--font-display);
    font-size: var(--fs-caption);
    font-weight: 500;
    cursor: pointer;
    /* Visible only on hover/focus so it doesn't crowd small code blocks.
       Always visible for keyboard users (opacity stays 1 when focused). */
    opacity: 0;
    transition: opacity 150ms ease, background-color 150ms ease, color 150ms ease;
  }

  /* Show on pre hover, and always when the button itself is focused/active. */
  :global(.prose pre:hover .prose-copy-btn),
  :global(.prose-copy-btn:focus-visible),
  :global(.prose-copy-btn:active) {
    opacity: 1;
  }

  :global(.prose-copy-btn:hover) {
    background: var(--brand-tint);
    color: var(--brand-ink);
    opacity: 1;
  }

  :global(.prose-copy-btn:focus-visible) {
    outline: 3px solid var(--focus-ring);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.prose-copy-btn) { transition: none; }
  }
</style>
