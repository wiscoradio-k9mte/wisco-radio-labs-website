---
// BlogPost.astro — article frame.
// Wraps BaseLayout, adds: hero image, eyebrow, H1, meta row, optional YouTube embed, prose slot.
// Also injects BlogPosting JSON-LD into <head> via the named "head" slot in BaseLayout.
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { withBase } from '../lib/link';
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  tags?: string[];
  youtube?: string;
}

const { title, description, pubDate, updatedDate, heroImage, tags = [], youtube } = Astro.props;

// JSON-LD: BlogPosting — per-article, injected into <head> via BaseLayout's head slot.
// Astro.url.href is the canonical URL for this post (site + base + slug, already correct).
const postSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  url: Astro.url.href,
  ...(tags.length > 0 ? { keywords: tags.join(', ') } : {}),
  author: {
    '@type': 'Person',
    name: 'Travis Engh',
    callSign: 'K9MTE',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Wisco Radio Labs',
  },
});

// Rough reading time: ~200 wpm. We don't have word count at layout render time,
// but the slot content will fill it. Omit estimate for now (accurate word count
// would need a remark plugin — noted as a future nice-to-have).
---
<BaseLayout title={title} description={description}>
  <!-- BlogPosting JSON-LD injected into <head> via BaseLayout's named slot.
       is:inline silences the Astro hint — intentionally a raw JSON block. -->
  <script is:inline type="application/ld+json" slot="head" set:html={postSchema} />

  <article class="blog-article">
    <!-- Hero image (full width, above the title) -->
    {heroImage && (
      <div class="article-hero-wrap">
        <Image
          src={heroImage}
          alt=""
          width={1200}
          height={675}
          class="article-hero-img"
          loading="eager"
          decoding="async"
        />
      </div>
    )}

    <!-- Article header -->
    <div class="article-header container">
      {tags.length > 0 && (
        <p class="eyebrow">{tags[0]}</p>
      )}
      <h1 class="article-title">{title}</h1>
      <p class="article-meta">
        <FormattedDate date={pubDate} />
        {updatedDate && updatedDate > pubDate && (
          <> &middot; Updated <FormattedDate date={updatedDate} /></>
        )}
        &middot; K9MTE
      </p>
    </div>

    <!-- Optional YouTube embed (above the prose) -->
    {youtube && (
      <div class="article-youtube container">
        <YouTubeEmbed id={youtube} title={title} />
      </div>
    )}

    <!-- Article body — Markdown rendered inside .prose -->
    <div class="article-body container">
      <div class="prose">
        <slot />
      </div>

      <!-- Tags at the bottom — plain labels, not links (tag filter not yet built). -->
      {tags.length > 0 && (
        <div class="article-tags">
          <hr />
          <div class="article-tags-list">
            <span class="article-tags-label">Tagged:</span>
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      )}

      <!-- Back link — readers who land deep-linked have no path onward without this. -->
      <p class="back-link-wrap">
        <a href={withBase('/blog/')}>&#8592; All posts</a>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article {
    padding-bottom: var(--space-12);
  }

  /* Hero */
  .article-hero-wrap {
    width: 100%;
    max-height: 480px;
    overflow: hidden;
    margin-bottom: var(--space-8);
  }

  .article-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }

  /* Header */
  .article-header {
    max-width: var(--measure);
    margin-block: var(--space-8);
  }

  .article-title {
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.015em;
    font-family: var(--font-display);
    color: var(--text);
    margin: 0 0 var(--space-4);
  }

  .article-meta {
    font-size: var(--fs-small);
    color: var(--text-muted);
    margin: 0;
  }

  /* YouTube */
  .article-youtube {
    max-width: var(--measure);
    margin-bottom: var(--space-6);
  }

  /* Body */
  .article-body {
    max-width: var(--measure);
  }

  /* Tags footer */
  .article-tags hr {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: var(--space-5);
  }

  .article-tags-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .article-tags-label {
    font-size: var(--fs-caption);
    font-weight: 500;
    color: var(--text-secondary);
    margin-right: var(--space-1);
  }

  .back-link-wrap {
    margin-top: var(--space-8);
    font-size: var(--fs-small);
  }
</style>
