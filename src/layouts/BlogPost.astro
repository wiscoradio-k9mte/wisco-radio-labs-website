---
// BlogPost.astro — article frame.
// Wraps BaseLayout, adds: hero image, eyebrow, H1, meta row, optional YouTube embed, prose slot.
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { withBase } from '../lib/link';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  tags?: string[];
  youtube?: string;
}

const { title, description, pubDate, updatedDate, heroImage, tags = [], youtube } = Astro.props;

// Rough reading time: ~200 wpm. We don't have word count at layout render time,
// but the slot content will fill it. Omit estimate for now (accurate word count
// would need a remark plugin — noted as a future nice-to-have).
---
<BaseLayout title={title} description={description}>
  <article class="blog-article">
    <!-- Hero image (full width, above the title) -->
    {heroImage && (
      <div class="article-hero-wrap">
        <Image
          src={heroImage}
          alt=""
          width={1200}
          height={675}
          class="article-hero-img"
          loading="eager"
          decoding="async"
        />
      </div>
    )}

    <!-- Article header -->
    <div class="article-header container">
      {tags.length > 0 && (
        <p class="eyebrow">{tags[0]}</p>
      )}
      <h1 class="article-title">{title}</h1>
      <p class="article-meta">
        <FormattedDate date={pubDate} />
        {updatedDate && updatedDate > pubDate && (
          <> &middot; Updated <FormattedDate date={updatedDate} /></>
        )}
        &middot; K9MTE
      </p>
    </div>

    <!-- Optional YouTube embed (above the prose) -->
    {youtube && (
      <div class="article-youtube container">
        <YouTubeEmbed id={youtube} title={title} />
      </div>
    )}

    <!-- Article body — Markdown rendered inside .prose -->
    <div class="article-body container">
      <div class="prose">
        <slot />
      </div>

      <!-- Tags at the bottom -->
      {tags.length > 0 && (
        <div class="article-tags">
          <hr />
          <div class="article-tags-list">
            {tags.map(tag => (
              <a href={withBase(`/blog/?tag=${encodeURIComponent(tag)}`)} class="tag">{tag}</a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article {
    padding-bottom: var(--space-12);
  }

  /* Hero */
  .article-hero-wrap {
    width: 100%;
    max-height: 480px;
    overflow: hidden;
    margin-bottom: var(--space-8);
  }

  .article-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }

  /* Header */
  .article-header {
    max-width: var(--measure);
    margin-block: var(--space-8);
  }

  .article-title {
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.015em;
    font-family: var(--font-display);
    color: var(--text);
    margin: 0 0 var(--space-4);
  }

  .article-meta {
    font-size: var(--fs-small);
    color: var(--text-muted);
    margin: 0;
  }

  /* YouTube */
  .article-youtube {
    max-width: var(--measure);
    margin-bottom: var(--space-6);
  }

  /* Body */
  .article-body {
    max-width: var(--measure);
  }

  /* Tags footer */
  .article-tags hr {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: var(--space-5);
  }

  .article-tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
