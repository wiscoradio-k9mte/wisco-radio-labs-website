---
// Contact — form (Web3Forms) + email + social/QRZ/YouTube links
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { CONTACT_EMAIL, SOCIAL_LINKS } from '../consts';
---
<BaseLayout
  title="Contact"
  description="Get in touch with Wisco Radio Labs (K9MTE) — questions, ideas, CW Trainer feedback, or just to say 73."
>
  <section class="section container contact-section">

    <h1 class="page-title">Get in touch</h1>
    <p class="page-lead">
      Questions, ideas, a bug in the CW Trainer? Want to talk radio? I'd like to hear from you.
    </p>

    <div class="contact-layout">

      <!-- Form (primary action) -->
      <div class="contact-form-col">
        <ContactForm />
      </div>

      <!-- Other ways to reach me -->
      <aside class="contact-links-col" aria-label="Other contact options">
        <h2 class="contact-links-heading">Other ways to reach me</h2>
        <ul class="contact-links" role="list">

          {CONTACT_EMAIL && (
            <li>
              <a href={`mailto:${CONTACT_EMAIL}`} class="contact-link" aria-label={`Email ${CONTACT_EMAIL}`}>
                <svg class="contact-icon" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
                <span>{CONTACT_EMAIL}</span>
              </a>
            </li>
          )}

          {SOCIAL_LINKS.qrz && (
            <li>
              <a href={SOCIAL_LINKS.qrz} class="contact-link" rel="noopener noreferrer" target="_blank"
                 aria-label="QRZ profile for K9MTE (opens in new tab)">
                <svg class="contact-icon" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <path d="M9 9h6"/>
                  <path d="M9 15h4"/>
                  <path d="M16 15l-3-6"/>
                </svg>
                <span>QRZ: K9MTE ↗</span>
              </a>
            </li>
          )}

          {SOCIAL_LINKS.youtube && (
            <li>
              <a href={SOCIAL_LINKS.youtube} class="contact-link" rel="noopener noreferrer" target="_blank"
                 aria-label="Wisco Radio Labs on YouTube (opens in new tab)">
                <svg class="contact-icon" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58z"/>
                  <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
                </svg>
                <span>YouTube ↗</span>
              </a>
            </li>
          )}

          {SOCIAL_LINKS.github && (
            <li>
              <a href={SOCIAL_LINKS.github} class="contact-link" rel="noopener noreferrer" target="_blank"
                 aria-label="Wisco Radio Labs on GitHub (opens in new tab)">
                <svg class="contact-icon" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/>
                </svg>
                <span>GitHub ↗</span>
              </a>
            </li>
          )}

          <!-- Show a note if no links are configured yet -->
          {!CONTACT_EMAIL && !SOCIAL_LINKS.qrz && !SOCIAL_LINKS.youtube && !SOCIAL_LINKS.github && (
            <li class="contact-links-placeholder">
              <!-- TODO: fill in CONTACT_EMAIL and SOCIAL_LINKS in src/consts.ts -->
              Contact links coming soon.
            </li>
          )}

        </ul>
      </aside>

    </div>

  </section>
</BaseLayout>

<style>
  .contact-section {
    padding-bottom: var(--space-12);
  }

  .page-title {
    font-size: var(--fs-h1);
    margin: 0 0 var(--space-4);
  }

  .page-lead {
    color: var(--text-secondary);
    font-size: var(--fs-body);
    max-width: 60ch;
    margin: 0 0 var(--space-8);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 768px) {
    .contact-layout {
      grid-template-columns: 3fr 2fr;
      align-items: start;
    }
  }

  .contact-links-heading {
    font-size: var(--fs-h4);
    color: var(--text);
    margin: 0 0 var(--space-5);
  }

  .contact-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    min-height: 48px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--fs-small);
    border-bottom: 1px solid var(--border);
    transition: color 150ms ease;
  }

  .contact-link:hover { color: var(--brand-ink); }
  .contact-link:focus-visible { outline: 3px solid var(--focus-ring); outline-offset: 2px; border-radius: var(--radius-sm); }

  .contact-icon {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .contact-link:hover .contact-icon { color: var(--brand); }

  .contact-links-placeholder {
    color: var(--text-muted);
    font-size: var(--fs-small);
    padding-block: var(--space-3);
  }
</style>
