---
// Blog index — card list, sorted newest first.
// Categories are shown as static chips (non-interactive in v1 — filtering is a future React island).
// Draft exclusion is centralized here with the same filter used in [...slug].astro and rss.xml.js.
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SignalWave from '../../components/SignalWave.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/link';

const allPosts = (await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect unique tags for the filter row
const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))].sort();
---
<BaseLayout title="Blog" description="Articles and build logs from Wisco Radio Labs (K9MTE) — ham radio, Morse code, electronics, and life in the Driftless.">

  <section class="section container">
    <h1 class="page-title">Blog</h1>
    <p class="page-lead">
      Build logs, experiments, and notes from the bench. Ham radio, CW, and whatever else
      I'm making in the Driftless.
    </p>

    <!-- Topic labels (static in v1 — non-interactive; React island tag filter is the future upgrade).
         Rendered as plain labels, not links, so there are no dead affordances. -->
    {allTags.length > 0 && (
      <div class="topics-row">
        <span class="topics-label">Topics:</span>
        {allTags.map(tag => (
          <span class="tag-label">{tag}</span>
        ))}
      </div>
    )}

    <!-- Subtle signal-wave divider between header and posts.
         Decorative only — restrained at low opacity per the design system. -->
    <SignalWave height={40} opacity={0.18} />

    <!-- h2 bridges the h1 "Blog" → h3 post-card-title gap in the heading outline.
         Visually hidden since the page title + lead already describe the section. -->
    <h2 class="sr-only">All posts</h2>

    <!-- Post grid -->
    {allPosts.length > 0 ? (
      <div class="posts-grid">
        {allPosts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            href={`/blog/${post.id}/`}
            heroImage={post.data.heroImage}
            tags={post.data.tags}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">
          <!-- Brand tower mark — scaled for the empty panel -->
          <svg width="72" height="72" viewBox="0 0 32 32">
            <circle cx="16" cy="16" r="14" fill="var(--surface-2)"/>
            <path d="M7 7 Q16 13 25 7" stroke="var(--brand)" stroke-width="1" fill="none"
                  stroke-linecap="round" opacity="0.5"/>
            <path d="M10 10 Q16 14 22 10" stroke="var(--brand)" stroke-width="1.2" fill="none"
                  stroke-linecap="round" opacity="0.8"/>
            <circle cx="16" cy="7" r="1.8" fill="var(--brand)"/>
            <path d="M16 8 L10 22 L14 22 L14 18 L18 18 L18 22 L22 22 Z"
                  fill="var(--brand)" opacity="0.75"/>
          </svg>
        </div>
        <p class="empty-state-title">Nothing here yet.</p>
        <p class="empty-state-text">
          I publish when there's something real to show.{' '}
          <a href={withBase('/')}>More coming.</a>
        </p>
      </div>
    )}
  </section>

</BaseLayout>

<style>
  .page-title {
    font-size: var(--fs-h1);
    margin: 0 0 var(--space-4);
  }

  .page-lead {
    color: var(--text-secondary);
    font-size: var(--fs-body);
    max-width: 60ch;
    margin: 0 0 var(--space-6);
  }

  /* Topics row — static labels; no hover, no pointer so they don't imply interactivity */
  .topics-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .topics-label {
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--text-secondary);
    margin-right: var(--space-1);
  }

  /* tag-label: plain muted text, no pill shape — scanners read "label" not "button" */
  .tag-label {
    display: inline-flex;
    align-items: center;
    color: var(--text-muted);
    font-size: var(--fs-caption);
    font-family: var(--font-body);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .posts-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* Empty-state panel — calm, on-brand, never broken-looking */
  .empty-state {
    padding: var(--space-12) 0 var(--space-10);
    text-align: center;
    color: var(--text-secondary);
  }

  .empty-state-icon {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-5);
    opacity: 0.7;
  }

  .empty-state-title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 500;
    color: var(--text);
    margin: 0 0 var(--space-3);
  }

  .empty-state-text {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    margin: 0;
  }
</style>
