---
// Individual blog article route.
// Astro 6 Content Layer: post.id (not post.slug), render() imported from astro:content.
// Using [...slug] so nested or dated filenames map cleanly.
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BlogPost
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  heroImage={post.data.heroImage}
  heroCaption={post.data.heroCaption}
  tags={post.data.tags}
  youtube={post.data.youtube}
>
  <Content />
</BlogPost>
